Language: C
BasedOnStyle: LLVM

# 基础缩进设置
IndentWidth: 4
UseTab: Never
TabWidth: 4

# 括号换行设置 - 所有括号都换行
BreakBeforeBraces: Allman # 大括号单独一行

# 控制语句括号
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: true
  AfterControlStatement: true # if/for/while等后面换行
  AfterEnum: true
  AfterFunction: true # 函数定义后面换行
  AfterNamespace: true
  AfterStruct: true
  AfterUnion: true
  BeforeElse: true # else前换行
  BeforeCatch: true
  BeforeWhile: true # do-while的while前换行

# 对齐设置
AlignConsecutiveAssignments: true # 连续赋值对齐
AlignConsecutiveDeclarations: true # 连续声明对齐
AlignTrailingComments: true # 尾部注释对齐

# 指针和对齐
PointerAlignment: Left

# 列宽
ColumnLimit: 100

# 空格设置
SpaceBeforeParens: ControlStatements # 控制语句后加空格
SpaceInEmptyParentheses: false
SpacesInParentheses: false

# 包含文件
SortIncludes: true

# C标准
Standard: C11
